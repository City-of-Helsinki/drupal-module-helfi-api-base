includes:
	- phpstan-baseline.neon
parameters:
  fileExtensions:
      - php
      - module
      - install
  paths:
    - ./
  excludePaths:
    - vendor
  level: 7
  treatPhpDocTypesAsCertain: false
  ignoreErrors:
    -
      message: '#^Unsafe usage of new static#'
      path: src/Plugin/migrate/source/HttpSourcePluginBase.php
