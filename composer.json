{
    "name": "drupal/helfi_api_base",
    "type": "drupal-module",
    "description": "Helfi - API Base",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "drupal/entity": "^1.0",
        "drupal/health_check": "^3.0",
        "drupal/monolog": "^3.0",
        "drupal/raven": "^6.0 || ^7.0",
        "drupal/redis": "^1.0",
        "firebase/php-jwt": "^7.0",
        "php": "^8.1",
        "t4web/composer-lock-parser": "^1.0",
        "phrity/websocket": "^3.6",
        "webmozart/assert": "^1.0",
        "ext-curl": "*",
        "symfony/polyfill-php84": "^1.0",
        "symfony/polyfill-php85": "^1.0",
        "city-of-helsinki/php-logger-extra": "^1.0"
    },
    "repositories": {
        "php-logger-extra": {
            "type": "vcs",
            "url": "https://github.com/City-of-Helsinki/php-logger-extra.git"
        }
    },
    "conflict": {
        "drupal/helfi_debug": "*"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.0",
        "drupal/coder": "^8.3",
        "drupal/search_api": "^1.0",
        "drupal/elasticsearch_connector": "^8.0@alpha",
        "donatj/mock-webserver": "dev-master"
    }
}
